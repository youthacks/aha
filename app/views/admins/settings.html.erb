<h1>Admin Settings</h1>

<h3>Username</h3>
<p><%= @admin.name %></p>
<h3>Email</h3>
<%= form_with url: change_email_path, method: :post do |form| %>
  <%= form.email_field :email, value: @admin.email, required: true %>
  <%= form.submit "Change Email" %>
<% end %>
<h3>Created At</h3>
<p><%= @admin.created_at.strftime("%B %d, %Y") %></p>
