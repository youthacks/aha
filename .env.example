# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password
DB_DATABASE=aha

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=1d

# Required to access admin/debug endpoints
ADMIN_API_KEY=your-strong-admin-key

NODE_ENV=development

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=AHA <your-email@gmail.com>

# App URLs
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001

# Youthacks OAuth
YOUTHACKS_BASE_URL=https://auth.youthacks.org
YOUTHACKS_CLIENT_ID=your-youthacks-client-id
YOUTHACKS_CLIENT_SECRET=your-youthacks-client-secret
YOUTHACKS_CALLBACK_URL=http://localhost:3000/auth/youthacks/callback

# Optional explicit Youthacks endpoints (usually inferred from YOUTHACKS_BASE_URL)
# YOUTHACKS_AUTH_URL=https://auth.youthacks.org/oauth/authorize
# YOUTHACKS_TOKEN_URL=https://auth.youthacks.org/oauth/token
# YOUTHACKS_USERINFO_URL=https://auth.youthacks.org/oauth/userinfo

